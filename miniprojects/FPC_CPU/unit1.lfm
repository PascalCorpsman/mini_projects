    Lines.Strings = (
      '; ------------------------------------------------------------'
      '; Demo Program: Sum of an Array using Function Calls'
      ';'
      '; This program demonstrates the core features of the CPU:'
      '; - Memory access (LOAD / STORE)'
      '; - Stack usage (PUSH / POP)'
      '; - Function calls (CALL / RET)'
      '; - Loops and conditional jumps'
      ';'
      '; What it does:'
      '; The program reads an array of values from memory and computes'
      '; the sum of all elements using a separate function.'
      ';'
      '; Memory layout:'
      '; Memory[100] = number of elements (N) (max 19)'
      '; Memory[101...] = array values'
      ';'
      '; The result (sum of all elements) is stored in Memory[119].'
      ';'
      '; The array is processed by calling a function (sumArray),'
      '; which receives its parameters via the stack and returns'
      '; the result on the stack.'
      '; ------------------------------------------------------------'
      ''
      '; --- Main Program ---'
      ''
      'LOAD A,100        ; A = N (number of elements)'
      'MOV B,101         ; B = start address of array'
      ''
      'PUSH B            ; push address (first parameter)'
      'PUSH A            ; push length  (second parameter)'
      ''
      'CALL sumArray     ; call function'
      ''
      'POP A             ; get result from stack'
      ''
      'STORE A,119       ; store result in memory'
      ''
      'HLT'
      ''
      ''
      '; ------------------------------------------------------------'
      '; Function: sumArray'
      '; Parameters (on stack):'
      ';   top -> length'
      ';          address'
      ';          return address (below, must remain untouched)'
      ';'
      '; Returns:'
      ';   pushes result (sum) onto the stack'
      '; ------------------------------------------------------------'
      ''
      'sumArray:'
      'POP D             ; Bakup Return Address to read out params'
      'POP C             ; C = length'
      'POP B             ; B = address'
      'PUSH D            ; temporarly store'
      ''
      'MOV D,0           ; D = sum (accumulator)'
      ''
      'loop:'
      ''
      'CMP C,0'
      'JZ end'
      ''
      'LOAD A,B          ; load value from memory'
      'ADD D,A           ; sum += value'
      ''
      'ADD B,1           ; next memory address'
      'SUB C,1           ; decrement counter'
      ''
      'JMP loop'
      ''
      'end:'
      'POP A'
      'PUSH D            ; push result onto stack'
      'PUSH A'
      ''
      'RET               ; return to caller'
    )
