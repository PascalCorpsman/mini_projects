    MouseActions = <>
    MouseTextActions = <>
    MouseSelActions = <>
    Lines.Strings = (
      '; Reads in mem address 100 => N'
      '; Calculates Sum = (N^2+N) / 2'
      '; Stores result at mem address 101'
      ''
      'LOAD A, 100     ; A = N'
      'ADD A, 1        ; Code below calculates to N-1, this fixes the off by 1 error ;)'
      ''
      'MOV B, 0        ; B = sum'
      'MOV C, 1        ; C = counter = 1'
      ''
      'LOOP:'
      'CMP C, A        ; compare counter with N'
      'JZ END          ; if C > N -> fertig (optional, sonst anders lösen)'
      ''
      'ADD B, C        ; sum += counter'
      'ADD C, 1        ; counter++'
      'JMP LOOP'
      ''
      'END:'
      'STORE B, 101    ; Ergebnis speichern'
      'HLT'
    )
    VisibleSpecialChars = [vscSpace, vscTabAtLast]
